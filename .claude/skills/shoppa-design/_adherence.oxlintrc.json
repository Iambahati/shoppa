{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/trust/**",
              "ui_kits/auth/**",
              "ui_kits/console/**",
              "ui_kits/verifier/**",
              "ui_kits/verify/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: type, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> type must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|tone|src|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, size, tone, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:solid|soft)$/]",
        "message": "<Avatar> tone must be one of 'solid' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: color, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:stone|emerald|amber|red|blue|purple)$/]",
        "message": "<Badge> color must be one of 'stone' | 'emerald' | 'amber' | 'red' | 'blue' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md)$/]",
        "message": "<Badge> size must be one of 'xs' | 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|loading|iconLeft|iconRight|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, loading, iconLeft, iconRight, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CertBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|certId|issuedAt|key|ref|className|style|children)$/]",
        "message": "<CertBadge> doesn't accept that prop. Declared props: status, certId, issuedAt."
      },
      {
        "selector": "JSXOpeningElement[name.name='CertBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:verified|in_review|pending|rejected|unverified)$/]",
        "message": "<CertBadge> status must be one of 'verified' | 'in_review' | 'pending' | 'rejected' | 'unverified'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|name|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, name, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|solid|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, solid, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|name|type|hint|error|required|textarea|rightSlot|value|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, name, type, hint, error, required, textarea, rightSlot, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|iconColor|trend|trendDir|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, icon, iconColor, trend, trendDir."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='iconColor'] > Literal[value!=/^(?:emerald|blue|amber|red|purple)$/]",
        "message": "<StatCard> iconColor must be one of 'emerald' | 'blue' | 'amber' | 'red' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='trendDir'] > Literal[value!=/^(?:up|down|neutral)$/]",
        "message": "<StatCard> trendDir must be one of 'up' | 'down' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerifiedPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|children|key|ref|className|style|children)$/]",
        "message": "<VerifiedPill> doesn't accept that prop. Declared props: size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerifiedPill'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<VerifiedPill> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
